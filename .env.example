# Existing Firebase frontend variables
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# Optional only if your AI API is hosted separately.
# For same Vercel project, leave this empty and the app will call /api/chat.
VITE_AI_API_URL=

# Server-only variables. Add these in Vercel Project Settings, not in React code.
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Llama provider config. Examples:
# Groq base URL: https://api.groq.com/openai/v1
# Official Llama compatible base URL: https://api.llama.com/compat/v1
LLAMA_API_KEY=
LLAMA_BASE_URL=https://api.groq.com/openai/v1
LLAMA_MODEL=llama-3.3-70b-versatile

# Optional: restrict API CORS when using separate frontend/backend domains.
CLIENT_URL=
